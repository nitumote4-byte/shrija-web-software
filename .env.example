# RAILWAY_API_URL=https://shrija-web-software-production.up.railway.app

# Backend (Railway)
# JWT_SECRET=long-random-string
# LICENSE_MASTER_SECRET=separate-secret-for-issuing-keys
# DATABASE_URL=postgresql://...
