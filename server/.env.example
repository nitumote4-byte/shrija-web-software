# Copy to .env for local development (never commit .env)

# PostgreSQL — Railway: use the Postgres service DATABASE_URL
# Local Docker: postgresql://shrija:shrija@localhost:5432/shrija
DATABASE_URL=postgresql://shrija:shrija@localhost:5432/shrija

# Required in production — long random string
JWT_SECRET=change-me-to-a-long-random-secret

# Comma-separated frontend origins (Vercel URL)
CORS_ORIGIN=http://localhost:5173

PORT=8787
NODE_ENV=development

# Set to false only for local Postgres without SSL
PGSSL=false
